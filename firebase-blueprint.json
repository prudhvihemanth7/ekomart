{
  "entities": {
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerEmail": { "type": "string", "format": "email" },
        "customerName": { "type": "string" },
        "address": { "type": "string" },
        "total": { "type": "number" },
        "items": { "type": "array" },
        "paymentMethod": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered"] }
      },
      "required": ["customerEmail", "customerName", "total", "items", "createdAt", "status"]
    },
    "Admin": {
      "title": "Admin",
      "description": "An administrator user",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin"] }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of orders"
    },
    "/admins/{adminId}": {
      "schema": "Admin",
      "description": "Collection of admin users"
    }
  }
}
