rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Master Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      // For Google Login, this is usually true. For Email/Password, it depends.
      // We will assume verified for now but check if possible.
      return request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'masshemanth587@gmail.com'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 2. Validation Blueprints
    function isValidOrder(data) {
      return data.keys().hasAll(['customerEmail', 'customerName', 'total', 'items', 'createdAt', 'status']) &&
             data.keys().size() >= 6 &&
             data.customerEmail is string && data.customerEmail.size() <= 200 &&
             data.customerName is string && data.customerName.size() <= 200 &&
             data.total is number &&
             data.items is list && data.items.size() <= 50 &&
             data.status in ['pending', 'processing', 'shipped', 'delivered'] &&
             data.createdAt == request.time;
    }

    function isValidAdmin(data) {
      return data.keys().hasAll(['email', 'role']) &&
             data.keys().size() == 2 &&
             data.email is string &&
             data.role == 'admin';
    }

    // 3. Collection rules
    match /orders/{orderId} {
      allow create: if isValidId(orderId) && isValidOrder(incoming());
      allow get, list, update, delete: if isAdmin();
      
      // Update logic for admins
      allow update: if isAdmin() && isValidOrder(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status'])
      );
    }

    match /admins/{adminId} {
      allow read, write: if isAdmin();
    }
  }
}
